# Скопируйте в .env (не коммитьте) — удобно для локали; на Рег.ру чаще задают токен в панели или в api/openrouter-token.local.php.
# В браузер и в index.html токен не попадает.
# OpenRouter: https://openrouter.ai/keys
Token=sk-or-v1-ВАШ_КЛЮЧ
# Альтернативное имя переменной:
# SARAN_OPENROUTER_TOKEN=sk-or-v1-…
#
# Рег.ру (shared PHP): чат ходит в api/openrouter-chat.php.
# Токен: переменные окружения Token / SARAN_OPENROUTER_TOKEN в панели, либо файл api/openrouter-token.txt,
# либо api/openrouter-token.local.php (см. api/openrouter-token.local.php.example). Файлы токена не коммитить.
#
# Hugging Face — NLLB перевод (api/nllb-translate.php), без VPS: https://huggingface.co/settings/tokens
# SARAN_HF_TOKEN=hf_…
# Альтернатива: HF_TOKEN, HUGGINGFACE_HUB_TOKEN, или api/hf-token.local.php / api/hf-token.txt (не коммитить).
# Опционально другая модель: SARAN_NLLB_HF_MODEL=facebook/nllb-200-distilled-600M
#
# Свой VPS с каталогом nllb-server/ (без HF): прокси PHP шлёт запросы сюда первым.
# SARAN_NLLB_SELF_HOST_URL=https://nllb.ваш-домен.ru
# SARAN_NLLB_SELF_HOST_API_KEY=тот_же_что_NLLB_API_KEY_на_VPS
#
# Vercel (Node): при необходимости остаётся api/openrouter-chat.js — тогда в JS можно указать window.SARAN_OPENROUTER_PROXY='/api/openrouter-chat'.
