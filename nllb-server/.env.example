# Модель: по умолчанию минимальная для слабого CPU/RAM.
NLLB_MODEL_ID=facebook/nllb-200-distilled-600M

# Слушать на всех интерфейсах (за nginx / firewall).
NLLB_HOST=0.0.0.0
NLLB_PORT=8088

# Опционально защитить API (заголовок X-API-Key с клиента и в SARAN_NLLB_SELF_HOST_API_KEY на PHP).
# NLLB_API_KEY=

NLLB_MAX_INPUT_CHARS=8000
NLLB_MAX_NEW_TOKENS=512
# Качество vs скорость на CPU: 1 быстрее, 3–4 точнее, но медленнее.
NLLB_NUM_BEAMS=2
